# ─── PRAMAANIK Environment Configuration ─────────────────────────────
# Copy this to .env and fill in your keys

# ─── Blockchain RPCs ──────────────────────────────────────────────────
BESU_RPC_URL=http://localhost:8545
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ─── Deployer / Publisher Key ─────────────────────────────────────────
# DO NOT USE HARDHAT DEV KEYS IN PRODUCTION
PRIVATE_KEY=

# ─── Contract Addresses (filled after deploy) ────────────────────────
BESU_ANCHOR_ADDRESS=
FUND_FLOW_ADDRESS=
ANOMALY_ORACLE_ADDRESS=
SCHEME_REGISTRY_ADDRESS=
GRIEVANCE_PORTAL_ADDRESS=
ACCESS_GOVERNANCE_ADDRESS=

# ─── IPFS / Pinata ───────────────────────────────────────────────────
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# ─── Neo4j ────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Change this in production
NEO4J_PASSWORD=

# ─── Privado ID ──────────────────────────────────────────────────────
PRIVADO_ISSUER_DID=
PRIVADO_ISSUER_KEY=

# ─── Pimlico (ERC-4337 Bundler) ──────────────────────────────────────
PIMLICO_API_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=http://localhost:8545
NEXT_PUBLIC_CHAIN_ID=1337
