# ─── PRAMAANIK Environment Configuration ─────────────────────────────
# Copy this to .env and fill in your keys

# ─── Blockchain RPCs ──────────────────────────────────────────────────
BESU_RPC_URL=http://localhost:8545
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ─── Deployer / Publisher Key ─────────────────────────────────────────
# DO NOT USE HARDHAT DEV KEYS IN PRODUCTION
PRIVATE_KEY=

# ─── Contract Addresses (filled after deploy) ────────────────────────
BESU_ANCHOR_ADDRESS=
FUND_FLOW_ADDRESS=
ANOMALY_ORACLE_ADDRESS=
SCHEME_REGISTRY_ADDRESS=
GRIEVANCE_PORTAL_ADDRESS=
ACCESS_GOVERNANCE_ADDRESS=
BATCH_VERIFIER_ADDRESS=
CONSTITUTIONAL_COMPLIANCE_ADDRESS=

# ─── Oracle API Keys (ChainLedger §4.2.3) ────────────────────────────
# GSTN Sandbox: https://apisandbox.gst.gov.in
GSTN_SANDBOX_URL=https://apisandbox.gst.gov.in
GSTN_API_KEY=
# NPCI NACH (bank deduplication)
NPCI_API_URL=
NPCI_API_KEY=
# NIC Geotag Verification
NIC_GEOTAG_API_URL=

# ─── IPFS / Pinata ───────────────────────────────────────────────────
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# ─── Neo4j ────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Change this in production — use a strong random password
NEO4J_PASSWORD=

# ─── Redis (EZKL Prover Job Queue) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Privado ID ──────────────────────────────────────────────────────
PRIVADO_ISSUER_DID=
PRIVADO_ISSUER_KEY=

# ─── Pimlico (ERC-4337 Bundler) ──────────────────────────────────────
PIMLICO_API_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=http://localhost:8545
NEXT_PUBLIC_CHAIN_ID=1337
